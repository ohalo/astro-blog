---
import { Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'

const headings = [
  { depth: 2, slug: 'hobbies', text: '兴趣爱好' },
  { depth: 2, slug: 'tools', text: '工具栈' },
  { depth: 2, slug: 'social-networks', text: '社交网络' },
  { depth: 2, slug: 'about-blog', text: '关于博客' }
]
---

<PageLayout title='关于我' {headings} comment>
  <p>一个 37 岁的创业者，正在探索 AI 时代的工作方式。</p>
  <p>
    Motto: Stay hungry, Stay foolish.
  </p>

  {/* hobbies */}
  <h2 id='hobbies'>兴趣爱好</h2>
  <ul>
    <li>AI 工具探索与应用</li>
    <li>创业思考与商业洞察</li>
    <li>技术实践与效率提升</li>
    <li>社会现象观察与分析</li>
  </ul>

  {/* tools */}
  <h2 id='tools'>工具栈</h2>
  <p>我日常使用的工具：</p>
  <ToolSection
    class='mb-5'
    title='AI 工具'
    tools={[
      {
        name: 'OpenClaw',
        description: 'AI 助手与自动化',
        href: 'https://openclaw.ai',
        icon: import('@/assets/tools/openclaw.svg?raw')
      },
      {
        name: 'HAFW',
        description: 'AI 开发流程管理',
        href: 'https://hafw.halo26812.eu.org/',
        icon: import('@/assets/tools/hafw.svg?raw')
      },
      {
        name: 'Claude',
        description: 'AI 对话与编程',
        href: 'https://claude.ai',
        icon: import('@/assets/tools/claude.svg?raw')
      },
      {
        name: 'ChatGPT',
        description: 'AI 对话与创作',
        href: 'https://chat.openai.com',
        icon: import('@/assets/tools/chatgpt.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='开发工具'
    tools={[
      {
        name: 'VS Code',
        description: '代码编辑器',
        href: 'https://code.visualstudio.com/',
        icon: import('@/assets/tools/vscode.svg?raw')
      },
      {
        name: 'GitHub',
        description: '代码托管与协作',
        href: 'https://github.com',
        icon: import('@/assets/tools/github.svg?raw')
      },
      {
        name: 'Astro',
        description: '静态网站生成器',
        href: 'https://astro.build',
        icon: import('@/assets/tools/astro.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='生产力'
    tools={[
      {
        name: 'Notion',
        description: '笔记与知识管理',
        href: 'https://www.notion.so/',
        icon: import('@/assets/tools/notion.svg?raw')
      },
      {
        name: 'Typora',
        description: 'Markdown 编辑器',
        href: 'https://typora.io/',
        icon: import('@/assets/tools/typora.svg?raw')
      }
    ]}
  />

  {/* social-networks */}
  <h2 id='social-networks'>社交网络</h2>
  <p>欢迎在各种平台找到我：</p>
  <Substats
    stats={[
      {
        platform: 'GitHub',
        icon: 'github',
        link: 'https://github.com/ohalo',
        text: 'followers',
        api: 'github/ohalo'
      },
      {
        platform: '知乎',
        icon: 'link',
        color: '#0084ff',
        link: 'https://www.zhihu.com/people/halo-67-80',
        text: 'followers',
        api: ''
      },
      {
        platform: 'HAFW',
        icon: 'link',
        color: '#2563eb',
        link: 'https://hafw.halo26812.eu.org/',
        text: 'HAFW',
        api: ''
      }
    ]}
  />

  {/* about-blog */}
  <h2 id='about-blog'>关于博客</h2>
  <p>这个博客的发展历程：</p>
  <Timeline
    events={[
      {
        date: '2026-04-07',
        content:
          '博客建立，使用 <a href="https://astro.build/" target="_blank">Astro</a> + <a href="https://github.com/cworld1/astro-theme-pure" target="_blank">Astro Theme Pure</a> 主题'
      },
      {
        date: '2026-05-21',
        content:
          '迁移到新主题，优化搜索功能和页面性能'
      },
      {
        date: '2026-05-22',
        content: '使用 OpenClaw AI 助手自动生成和发布文章'
      }
    ]}
  />
  <p>
    博客的正常运行依赖于以下优秀项目/服务提供者的资源和技术支持：
  </p>
  <ul>
    <li>域名：<a href='https://blog.halo26812.eu.org' target='_blank'>blog.halo26812.eu.org</a></li>
    <li>
      框架与主题：<a href='https://astro.build/' target='_blank'>Astro</a> + <a
        href='https://github.com/cworld1/astro-theme-pure'
        target='_blank'>Astro Theme Pure</a
      >
    </li>
    <li>
      网站托管：<a href='https://vercel.com/' target='_blank'>Vercel</a>
    </li>
    <li>
      CI/CD：<a href='https://vercel.com/workflow' target='_blank'>Vercel Workflow</a>
    </li>
    <li>评论系统：<a href='https://waline.js.org' target='_blank'>Waline</a></li>
    <li>
      访问统计：<a href='https://supabase.com/' target='_blank'>Supabase</a> +
      <a href='https://waline.js.org/' target='_blank'>Waline</a>
    </li>
  </ul>
</PageLayout>
