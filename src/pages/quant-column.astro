---
import SimpleLayout from '../layouts/SimpleLayout.astro';
import { getCollection } from 'astro:content';

let allPosts = [];
let quantPosts = [];
let beginnerPosts = [];
let intermediatePosts = [];
let advancedPosts = [];
let uncategorizedPosts = [];
let errorMsg = null;

try {
  // 获取所有博客文章
  allPosts = await getCollection('blog');
  console.log('Total posts:', allPosts.length);
  
  // 过滤量化相关文章（通过标签判断）
  quantPosts = allPosts.filter(post => 
    post.data.tags?.some(tag => 
      tag.includes('量化') || 
      tag.includes('quant') ||
      tag.includes('交易') ||
      tag.includes('投资')
    )
  );
  console.log('Quant posts:', quantPosts.length);
  
  // 按难度分类
  beginnerPosts = quantPosts.filter(post => post.data.difficulty === 'beginner');
  intermediatePosts = quantPosts.filter(post => post.data.difficulty === 'intermediate');
  advancedPosts = quantPosts.filter(post => post.data.difficulty === 'advanced');
  uncategorizedPosts = quantPosts.filter(post => !post.data.difficulty);
  
  console.log('Beginner:', beginnerPosts.length);
  console.log('Intermediate:', intermediatePosts.length);
  console.log('Advanced:', advancedPosts.length);
  console.log('Uncategorized:', uncategorizedPosts.length);
} catch (e) {
  errorMsg = e.message;
  console.error('Error:', e);
}

const title = '量化专栏 - 完整版（调试中）';
const description = '逐步调试完整模板';
---

<SimpleLayout title={title} description={description}>
  <h1>量化专栏 - 完整版（调试中）</h1>
  
  {errorMsg && (
    <div style="background: #fee; padding: 1rem; border-radius: 8px; margin: 1rem 0;">
      <h2>❌ 错误</h2>
      <p>{errorMsg}</p>
    </div>
  )}
  
  {!errorMsg && (
    <>
      <h2>✅ 数据获取成功</h2>
      <p>总文章数: {allPosts.length}</p>
      <p>量化相关文章: {quantPosts.length}</p>
      <hr />
      <h3>分类统计</h3>
      <ul>
        <li>🌱 入门: {beginnerPosts.length} 篇</li>
        <li>📈 进阶: {intermediatePosts.length} 篇</li>
        <li>🚀 高阶: {advancedPosts.length} 篇</li>
        <li>📚 未分类: {uncategorizedPosts.length} 篇</li>
      </ul>
      
      <hr />
      <h3>未分类文章列表（前10篇）</h3>
      <ul>
        {uncategorizedPosts.slice(0, 10).map(post => (
          <li>
            <strong>{post.data.title}</strong><br />
            <small>发布日期: {post.data.pubDate.toISOString().split('T')[0]}</small><br />
            <small>标签: {post.data.tags?.join(', ')}</small><br />
            <small>difficulty字段: {post.data.difficulty || '未设置'}</small>
          </li>
        ))}
      </ul>
    </>
  )}
  
  <a href="/" style="display: inline-block; margin-top: 2rem;">← 返回首页</a>
</SimpleLayout>
