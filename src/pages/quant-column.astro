---
import SimpleLayout from '../layouts/SimpleLayout.astro';
import { getCollection } from 'astro:content';

let allPosts = [];
let quantPosts = [];
let beginnerPosts = [];
let intermediatePosts = [];
let advancedPosts = [];
let uncategorizedPosts = [];
let errorMsg = null;

try {
  // 获取所有博客文章
  allPosts = await getCollection('blog');
  console.log('Total posts:', allPosts.length);
  
  // 过滤量化相关文章（通过标签判断）
  quantPosts = allPosts.filter(post => 
    post.data.tags?.some(tag => 
      tag.includes('量化') || 
      tag.includes('quant') ||
      tag.includes('交易') ||
      tag.includes('投资')
    )
  );
  console.log('Quant posts:', quantPosts.length);
  
  // 按难度分类
  beginnerPosts = quantPosts.filter(post => post.data.difficulty === 'beginner');
  intermediatePosts = quantPosts.filter(post => post.data.difficulty === 'intermediate');
  advancedPosts = quantPosts.filter(post => post.data.difficulty === 'advanced');
  uncategorizedPosts = quantPosts.filter(post => !post.data.difficulty);
  
  console.log('Beginner:', beginnerPosts.length);
  console.log('Intermediate:', intermediatePosts.length);
  console.log('Advanced:', advancedPosts.length);
  console.log('Uncategorized:', uncategorizedPosts.length);
} catch (e) {
  errorMsg = e.message;
  console.error('Error:', e);
}

const title = '量化专栏 - 测试 v10';
const description = '简化模板，只显示统计';
---

<SimpleLayout title={title} description={description}>
  <h1>量化专栏 - 测试 v10</h1>
  <p>简化模板：只显示统计，不渲染文章列表</p>
  
  {errorMsg && (
    <div style="background: #fee; padding: 1rem; border-radius: 8px; margin: 1rem 0;">
      <h2>❌ 错误</h2>
      <p>{errorMsg}</p>
    </div>
  )}
  
  {!errorMsg && (
    <div style="background: #efe; padding: 1rem; border-radius: 8px; margin: 1rem 0;">
      <h2>✅ 数据获取成功</h2>
      <p>总文章数: {allPosts.length}</p>
      <p>量化相关文章: {quantPosts.length}</p>
      <hr style="margin: 1rem 0;" />
      <p>🌱 入门: {beginnerPosts.length} 篇</p>
      <p>📈 进阶: {intermediatePosts.length} 篇</p>
      <p>🚀 高阶: {advancedPosts.length} 篇</p>
      <p>📚 未分类: {uncategorizedPosts.length} 篇</p>
      
      <hr style="margin: 1rem 0;" />
      <p><strong>下一步：</strong>如果此页面正常显示，再逐步添加文章列表。</p>
      
      <hr style="margin: 1rem 0;" />
      <h3>未分类文章（前5篇）</h3>
      <ul>
        {uncategorizedPosts.slice(0, 5).map(post => (
          <li style="margin-bottom: 1rem; padding: 1rem; border: 1px solid #e9ecef; border-radius: 8px;">
            <a href={`/blog/${post.id}/`} style="font-size: 1.1rem; font-weight: bold; color: #333; text-decoration: none;">{post.data.title}</a>
            <p style="color: #666; margin: 0.5rem 0; font-size: 0.9rem;">{post.data.description}</p>
            <small style="color: #999;">发布日期: {post.data.pubDate.toISOString().split('T')[0]}</small>
          </li>
        ))}
      </ul>
    </div>
  )}
  
  <a href="/" style="display: inline-block; margin-top: 2rem;">← 返回首页</a>
</SimpleLayout>
