---
import { getCollection } from 'astro:content';

let uncategorizedPosts = [];
let errorMsg = null;

try {
  const allPosts = await getCollection('blog');
  console.log('Total posts:', allPosts.length);
  
  const quantPosts = allPosts.filter(post => 
    post.data.tags?.some(tag => 
      tag.includes('量化') || 
      tag.includes('quant') ||
      tag.includes('交易') ||
      tag.includes('投资')
    )
  );
  console.log('Quant posts:', quantPosts.length);
  
  uncategorizedPosts = quantPosts.filter(post => !post.data.difficulty);
  console.log('Uncategorized:', uncategorizedPosts.length);
} catch (e) {
  errorMsg = e.message;
  console.error('Error:', e);
}
---

<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>量化专栏 - 无 Layout 测试</title>
  <style>
    body { font-family: system-ui, sans-serif; max-width: 1000px; margin: 0 auto; padding: 2rem 1rem; }
    h1 { color: #333; }
    .article { padding: 1rem; border: 1px solid #e9ecef; border-radius: 8px; margin-bottom: 1rem; }
    .article a { color: #667eea; text-decoration: none; font-weight: bold; }
    .desc { color: #666; font-size: 0.9rem; margin: 0.5rem 0; }
    .date { color: #999; font-size: 0.85rem; }
  </style>
</head>
<body>
  <h1>📊 量化专栏 - 无 Layout 测试 v17</h1>
  <p>测试：不使用 SimpleLayout，直接用纯 HTML</p>
  
  {errorMsg && (
    <div style="background: #fee; padding: 1rem; border-radius: 8px; margin: 1rem 0;">
      <h2>❌ 错误</h2>
      <p>{errorMsg}</p>
    </div>
  )}
  
  {!errorMsg && (
    <div>
      <h2>✅ 数据获取成功</h2>
      <p>未分类文章数: {uncategorizedPosts.length}</p>
      
      <hr style="margin: 1rem 0;" />
      
      <h3>未分类文章列表（前10篇）</h3>
      <div>
        {uncategorizedPosts.slice(0, 10).map(post => (
          <div class="article">
            <a href={`/blog/${post.id}/`}>{post.data.title}</a>
            <p class="desc">{post.data.description || '暂无描述'}</p>
            <small class="date">{post.data.pubDate?.toISOString().split('T')[0] || '未知日期'}</small>
          </div>
        ))}
      </div>
    </div>
  )}
  
  <a href="/" style="display: inline-block; margin-top: 2rem;">← 返回首页</a>
</body>
</html>
