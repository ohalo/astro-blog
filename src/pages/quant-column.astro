---
import SimpleLayout from '../layouts/SimpleLayout.astro';

const title = '量化专栏 - 调试 v6';
const description = '测试页面渲染';
---

<SimpleLayout title={title} description={description}>
  <h1>量化专栏 - 调试版本 v6</h1>
  <p>如果你看到这个页面，说明基础渲染正常。</p>
  
  <div style="background: #f0f0f0; padding: 1rem; margin: 1rem 0; border-radius: 8px;">
    <h2>调试信息</h2>
    <p>✅ SimpleLayout 导入成功</p>
    <p>✅ 页面渲染成功</p>
    <p>⏳ 等待添加 getCollection...</p>
  </div>
  
  <a href="/" style="display: inline-block; margin-top: 2rem;">← 返回首页</a>
</SimpleLayout>
