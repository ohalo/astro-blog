---
import { Button, Collapse, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import ProjectSection from '@/components/projects/ProjectSection.astro'

const headings = [
  { depth: 2, slug: 'programs', text: '开源项目' },
  { depth: 2, slug: 'learnings', text: '学习项目' },
  { depth: 2, slug: 'others', text: '其他' }
]
---

<PageLayout title='项目' headings={headings} view>
  <p>GitHub 活动图：</p>
  <p>
    <img
      src='https://ghchart.rshah.org/659eb9/ohalo'
      alt='GitHub 活动'
      loading='lazy'
    />
  </p>

  <p>
    如果你对我的项目感兴趣，或者想要合作，欢迎联系我讨论。
  </p>

  <h2 id='programs'>开源项目</h2>
  <ProjectSection
    projects={[
      {
        name: 'HAFW',
        description: 'AI 智能开发设计的综合管理与协作平台，提供从需求分析到部署运维的完整开发流程支持',
        image: '/src/assets/projects/hafw.png',
        links: [
          { type: 'site', href: 'https://hafw.halo26812.eu.org/' },
          { type: 'github', href: 'https://github.com/ohalo/hafw-platform' },
          { type: 'doc', href: 'https://hafw.halo26812.eu.org/repo/INSTALL.md' }
        ]
      },
      {
        name: 'Bookmarks Topic',
        description: '智能书签管理器浏览器扩展，支持 WebDAV 云同步、断链检测、重复合并、使用统计',
        image: '/src/assets/projects/bookmarkstopic.png',
        links: [
          { type: 'github', href: 'https://github.com/ohalo/bookmarkstopic' }
        ]
      }
    ]}
  />

  <h2 id='learnings'>学习项目</h2>
  <ProjectSection
    class='my-2'
    projects={[
      // 在这里添加你的学习项目
    ]}
  />

  <h2 id='others'>其他</h2>
  <ProjectSection
    projects={[
      {
        name: 'halo 的 GitHub',
        description: '我的 GitHub 主页',
        links: [{ type: 'github', href: 'https://github.com/ohalo' }]
      }
    ]}
  />
</PageLayout>
