---
import { Button, Collapse, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import ProjectSection from '@/components/projects/ProjectSection.astro'

const headings = [
  { depth: 2, slug: 'programs', text: '开源项目' },
  { depth: 2, slug: 'learnings', text: '学习项目' },
  { depth: 2, slug: 'others', text: '其他' }
]
---

<PageLayout title='项目' headings={headings} view>
  <!-- 关于 astro-pure -->
  <div class='not-prose flex justify-center'>
    <a
      href='/docs/advanced/about'
      target='_blank'
      class='flex items-center gap-x-3 rounded-full border bg-background px-4 py-2 text-sm shadow-sm transition-shadow hover:shadow-md'
    >
      <span class='size-2 rounded-full bg-green-400'></span>
      <p class='font-medium text-muted-foreground'>关于 Astro-Theme-Pure 主题</p>
    </a>
  </div>

  <p>GitHub 活动图：</p>
  <p>
    <img
      src='https://ghchart.rshah.org/659eb9/ohalo'
      alt='GitHub 活动'
      loading='lazy'
    />
  </p>

  <p>
    如果你对我的项目感兴趣，或者想要合作，欢迎联系我讨论。
  </p>

  <h2 id='programs'>开源项目</h2>
  <ProjectSection
    projects={[
      // 在这里添加你的开源项目
    ]}
  />

  <h2 id='learnings'>学习项目</h2>
  <ProjectSection
    class='my-2'
    projects={[
      // 在这里添加你的学习项目
    ]}
  />

  <h2 id='others'>其他</h2>
  <ProjectSection
    projects={[
      {
        name: 'halo 的 GitHub',
        description: '我的 GitHub 主页',
        links: [{ type: 'github', href: 'https://github.com/ohalo' }]
      }
    ]}
  />
</PageLayout>
